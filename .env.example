# ─── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── AI ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Maps ────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-maps-key
GOOGLE_GEOCODING_API_KEY=your-geocoding-key
GOOGLE_PLACES_API_KEY=your-places-key

# ─── Payments ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── SMS ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Booking ─────────────────────────────────────────────
CALENDLY_CLIENT_ID=your-client-id
CALENDLY_CLIENT_SECRET=your-client-secret
CALENDLY_WEBHOOK_SECRET=your-webhook-secret

# ─── Notifications ───────────────────────────────────────
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_API_KEY=your-api-key

# ─── NPI Registry ────────────────────────────────────────
NPI_REGISTRY_BASE_URL=https://npiregistry.cms.hhs.gov/api

# ─── Affiliate networks (perks-redemption-webhook) ───────
# Set one per network actually contracted. Absent secret ⇒ that network's
# webhook path is rejected with 403 (see perks-redemption-webhook/index.ts).
# PERKS_WEBHOOK_SECRET=...       # partner-direct ("direct" network) shared token
# IMPACT_WEBHOOK_SECRET=...      # Impact Partner "Auth Token" (HMAC-SHA256 of raw body)
# SHAREASALE_API_SECRET=...      # ShareASale API Secret (HMAC signs secret:ts:method:path)
# CJ_ALLOWED_IPS=1.2.3.4,5.6.7.8 # CJ gateway IPs (CJ does not sign — IP allowlist)

# ─── Mobile (Expo public — prefix required) ──────────────
EXPO_PUBLIC_API_BASE_URL=https://your-project.supabase.co/functions/v1
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-app-id

# ─── Observability ───────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
EXPO_PUBLIC_APP_ENV=development   # development | staging | production

# ─── Agents runtime (INTERNAL ONLY) ──────────────────────
# Starter agent runtime reachable only by Edge Functions agents-health /
# agents-triage / agents-run. Mobile must NEVER know AGENT_BASE_URL —
# it talks to Village Edge Functions, which proxy to this URL.
# AGENT_BASE_URL=http://host.docker.internal:8000
# AGENTS_BRIDGE_SECRET=change-me   # optional; forwarded as x-agents-secret
# EXPO_PUBLIC_INTERNAL_AGENTS_ENABLED=0   # 1 = compile the hidden debug console into the app

# ─── Edge Function secrets (set in Supabase Dashboard → Settings → Secrets) ─
# Never commit real values. These are only listed here for documentation.
# SUPABASE_URL          (auto-injected)
# SUPABASE_ANON_KEY     (auto-injected)
# SUPABASE_SERVICE_ROLE_KEY (auto-injected)
# ANTHROPIC_API_KEY
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET
# TWILIO_ACCOUNT_SID
# TWILIO_AUTH_TOKEN
# TWILIO_PHONE_NUMBER
# CALENDLY_WEBHOOK_SECRET
# ONESIGNAL_APP_ID
# ONESIGNAL_API_KEY
# AGENT_BASE_URL
# AGENTS_BRIDGE_SECRET
#
# ─── Specialist invite email (Resend) ─────────────────────────────────
# Required for specialist-invite-create edge function to send real invite
# emails. If unset, the function falls back to console.log (dev behavior).
# Set up at https://resend.com → verify your sending domain → API key.
# RESEND_API_KEY
# INVITE_FROM_EMAIL=villie <invites@villieapp.com>
# INVITE_REPLY_TO=hello@villieapp.com
# WEB_ONBOARD_URL_BASE=https://villieapp.com/onboard   # static onboarding page
