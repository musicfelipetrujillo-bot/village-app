{
  "expo": {
    "name": "villie",
    "slug": "the-village-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4ECD8"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.villieapp.mobile",
      "buildNumber": "5",
      "entitlements": {
        "keychain-access-groups": [
          "$(AppIdentifierPrefix)com.villieapp.mobile"
        ]
      },
      "associatedDomains": [
        "applinks:villieapp.com",
        "applinks:www.villieapp.com"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "villie uses your location to find nearby donors, specialists, and events.",
        "NSLocationAlwaysUsageDescription": "villie uses your location to find nearby donors, specialists, and events.",
        "NSCameraUsageDescription": "Used to take profile photos, gear listing photos, and scan product barcodes.",
        "NSPhotoLibraryUsageDescription": "Used to upload profile photos and gear listing photos.",
        "NSPhotoLibraryAddUsageDescription": "Save photos you take in villie to your library.",
        "NSMicrophoneUsageDescription": "Only used if you record video when listing an item.",
        "NSCalendarsUsageDescription": "Add events you RSVP to your calendar.",
        "NSCalendarsFullAccessUsageDescription": "Add events you RSVP to your calendar.",
        "NSContactsUsageDescription": "Share villie with contacts you choose.",
        "NSUserNotificationsUsageDescription": "Notifications for appointments, new donors, and community messages.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.villieapp.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F4ECD8"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "villieapp.com",
              "pathPrefix": "/m/"
            },
            {
              "scheme": "https",
              "host": "villieapp.com",
              "pathPrefix": "/manual/v/"
            },
            {
              "scheme": "https",
              "host": "www.villieapp.com",
              "pathPrefix": "/m/"
            },
            {
              "scheme": "https",
              "host": "www.villieapp.com",
              "pathPrefix": "/manual/v/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#C07840"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "villie uses your location to find nearby donors, specialists, and events."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow villie to access your camera to take listing photos and scan product barcodes.",
          "microphonePermission": "Only used if you record video when listing an item.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow villie to access your photos to upload profile and listing images.",
          "cameraPermission": "Allow villie to access your camera to take listing photos."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Add events you RSVP to your calendar."
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.595113218342-hh6m9dpe7go27mpri9hqlb9udvi88kb2"
        }
      ],
      "@sentry/react-native",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.villieapp.mobile"
        }
      ],
      "expo-font",
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ]
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.villieapp.mobile.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.villieapp.mobile.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "4b786f88-d387-4aba-a420-dfae6db88671"
      }
    },
    "runtimeVersion": "1.0.0",
    "owner": "villagepeople"
  }
}
