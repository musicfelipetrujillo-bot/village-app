# EAS Build calls `node_modules/.pnpm/expo@.../node_modules/expo/bin/cli`
# directly without going through pnpm's bin wrapper that sets NODE_PATH.
# Without hoisting `@expo/cli` becomes unresolvable from the bin script,
# and `expo config --json` exits 1 with no output.
#
# `node-linker=hoisted` rebuilds node_modules in classic npm/yarn flat
# layout so the bin script's `require('@expo/cli')` walks up and finds
# the package the way EAS expects.
node-linker=hoisted
